# --- Database ------------------------------------------------
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///./vins_faq.db

# PostgreSQL (uncomment and fill in for production):
# DATABASE_URL=postgresql://username:password@localhost:5432/vins_faq

# --- App settings --------------------------------------------
# Set to "production" in deployment
APP_ENV=development
